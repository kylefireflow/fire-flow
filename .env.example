# ─── Supabase (required for database persistence + auth) ─────────────────────
# Find these at: Supabase dashboard → Settings → API
SUPABASE_URL=https://mklldyjjqldzbcbhwdsu.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# JWT secret for verifying user tokens — Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Set to true during local development to skip auth checks on all routes
# NEVER set this in production
DISABLE_AUTH=false

# ─── AI service URLs (defaults work if running locally) ───────────────────────
VOICE_SERVICE_URL=http://localhost:3000
IMAGE_SERVICE_URL=http://localhost:3001
QUOTE_SERVICE_URL=http://localhost:3002

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_your_api_key_here
# The "from" address — must be a verified domain in Resend, or use their test address
FROM_EMAIL=Fire Flow <noreply@yourdomain.com>

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3003
